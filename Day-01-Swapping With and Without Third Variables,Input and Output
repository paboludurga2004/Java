Compound Interest:-
class Solution {
    static int getCompundInterest(int P, int T, int N, int R) {
        // code here
        double ratePerPeriod = (double) R / (100 * N);

        // Apply compound interest formula
        double amount = P * Math.pow(1 + ratePerPeriod, N * T);

        // Return floor of the value
        return (int) Math.floor(amount);
    }
}

